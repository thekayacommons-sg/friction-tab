{
  "manifest_version": 3,
  "name": "Friction Tab",
  "version": "0.1.0",
  "description": "Multitasking is a myth. A little friction and a little enforcement go a long way in retaining focus.",
  "permissions": ["storage", "notifications", "alarms"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Friction Tab"
  }
}
